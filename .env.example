# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token (HTML tag method)
# Get from: Search Console → Add Property → HTML tag → copy the content="..." value only
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Resend API key for contact form emails (https://resend.com)
RESEND_API_KEY=

# Email address to receive contact form submissions
CONTACT_TO_EMAIL=mails2arka@gmail.com
